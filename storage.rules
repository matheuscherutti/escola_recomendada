rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /certificates/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
                   && request.resource.size < 10 * 1024 * 1024; // Máximo 10MB por certificado
    }
  }
}
